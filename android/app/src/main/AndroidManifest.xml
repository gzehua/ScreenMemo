<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.fqyw.screen_memo">

    <!-- 权限声明 -->
    <!-- 无障碍服务权限 -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />

    <!-- 无障碍服务截屏不需要媒体投影权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- 存储权限 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
 
    <!-- 通知权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 精确闹钟（Android 12+ 精确定时触发需要此权限，并由用户在“Alarms & reminders”中允许） -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
 
    <!-- 网络权限（如果需要上传截图） -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- App 内下载 APK 后交给系统安装器安装更新 -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- 唤醒锁权限，确保服务持续运行 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 开机自启权限 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- 忽略电池优化权限 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- 使用统计权限，用于获取前台应用 -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:label="@string/app_name"
        android:name=".ScreenMemoApplication"
        android:icon="@mipmap/ic_launcher"
        android:localeConfig="@xml/locales_config"
        android:usesCleartextTraffic="true">
        <!-- 禁用 Impeller，回退到 Skia 以避免部分设备冷启动首帧缓慢/驱动异常 -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />
        <!-- 可选：强制使用 OpenGL ES 渲染 -->
        <meta-data
            android:name="io.flutter.embedding.android.Impeller.Renderer"
            android:value="opengles" />
        <!-- 启用 Sqflite WAL（Write-Ahead Logging）以提升写入并发性能 -->
        <meta-data
            android:name="com.tekartik.sqflite.wal_enabled"
            android:value="true" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- 主 Activity，启动入口由 activity-alias 控制图标与名称 -->
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <!-- LAUNCHER moved to activity-alias for dynamic label switching -->
        </activity>

        <!-- Launcher aliases for dynamic label switching -->
        <activity-alias
            android:name=".LauncherAliasZh"
            android:exported="true"
            android:enabled="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherAliasEn"
            android:exported="true"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name_en"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherAliasJa"
            android:exported="true"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name_ja"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherAliasKo"
            android:exported="true"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name_ko"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>

        <!-- 无障碍服务声明 -->
        <service
            android:name=".capture.ScreenCaptureAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 前台服务声明 -->
        <service
            android:name=".capture.ScreenCaptureService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="specialUse">
	            <property
	                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="@string/fgs_special_use_subtype" />
        </service>

        <service
            android:name=".importing.ImportOcrRepairService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".dynamic.DynamicRebuildService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync" />

        <!-- 守护服务（已禁用，避免重复前台通知） -->
        <!--
        <service
            android:name=".service.DaemonService"
            android:process=":daemon"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync" />
        -->
            
        <!-- AccessibilityService桥接服务 -->
        <service
            android:name=".capture.AccessibilityBridgeService"
            android:process=":accessibility"
            android:exported="false" />
            
        <!-- JobService保活服务 -->
        <service
            android:name=".service.KeepAliveJobService"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="true" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
 
        <!-- 每日总结提醒闹钟接收器 -->
        <receiver
            android:name=".daily.DailySummaryAlarmReceiver"
            android:exported="false" />

        <!-- App 运行状态 1 分钟健康检测闹钟接收器 -->
        <receiver
            android:name=".health.AppHealthAlarmReceiver"
            android:exported="false" />
 
        <!-- 开机自启接收器 -->
        <receiver
            android:name=".service.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- 服务重启接收器 -->
        <receiver
            android:name=".service.RestartReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter android:priority="1000">
                <action android:name="com.fqyw.screen_memo.RESTART_SERVICE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>
        
        <!-- 系统事件接收器 -->
        <receiver
            android:name=".service.SystemEventReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter android:priority="999">
                <!-- 屏幕解锁 -->
                <action android:name="android.intent.action.USER_PRESENT" />
                <!-- 屏幕亮起 -->
                <action android:name="android.intent.action.SCREEN_ON" />
                <!-- 屏幕熄灭 -->
                <action android:name="android.intent.action.SCREEN_OFF" />
                <!-- 电源连接 -->
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
                <!-- 时间变化 -->
                <action android:name="android.intent.action.TIME_TICK" />
                <!-- 网络变化 -->
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
            </intent-filter>
            <intent-filter>
                <!-- 自定义广播 -->
                <action android:name="com.fqyw.screen_memo.TRIGGER_ACCESSIBILITY_RECONNECT" />
                <action android:name="com.fqyw.screen_memo.RESTART_DAEMON" />
            </intent-filter>
        </receiver>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
