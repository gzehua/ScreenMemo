<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fg_notif_expanded_root"
    android:layout_width="match_parent"
    android:layout_height="21dp"
    android:gravity="center_vertical"
    android:minHeight="0dp"
    android:orientation="horizontal"
    android:paddingTop="0dp"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:paddingBottom="0dp">

    <ImageView
        android:id="@+id/fg_notif_app_icon"
        android:layout_width="21dp"
        android:layout_height="21dp"
        android:layout_marginEnd="6dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/app_name"
        android:scaleType="centerInside"
        android:src="@mipmap/ic_launcher" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/fg_notif_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/fg_notif_toggle"
        android:layout_width="21dp"
        android:layout_height="21dp"
        android:layout_marginStart="8dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/fg_notif_action_start_capture"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_notification_camera" />
</LinearLayout>
